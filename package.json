{
  "name": "sveltekit-omakase",
  "version": "5.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "postinstall": "npx simple-git-hooks",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "eslint .",
    "fix": "prettier --write . && eslint . --fix",
    "test:e2e": "playwright test",
    "test:unit": "vitest",
    "test": "playwright test && vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:drop": "drizzle-kit drop",
    "db:clear": "vite-node --options.transformMode.ssr='/.*/' src/lib/db/clear",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.8.0",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.6.2",
    "bits-ui": "2.18.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.4.0",
    "lint-staged": "^17.0.4",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "simple-git-hooks": "^2.13.1",
    "svelte": "5.55.5",
    "svelte-check": "^4.4.6",
    "svelte-sonner": "^1.1.0",
    "sveltekit-flash-message": "^2.4.6",
    "sveltekit-rate-limiter": "^0.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.11",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.4",
    "zod": "4.4.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@better-svelte-email/components": "^2.0.0-beta.4",
    "@better-svelte-email/server": "^2.0.0-beta.4",
    "@libsql/client": "^0.17.2",
    "better-auth": "^1.6.10",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.7",
    "resend": "^6.10.0",
    "uuid": "^14.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,svelte,json,css,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
